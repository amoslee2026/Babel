<?xml version="1.0" ?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Babel</vendor>
  <name>M06_ClockManager</name>
  <version>1.0</version>
  <description>M06_ClockManager Register Map</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <cpu>
    <name>CM0</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
  </cpu>
  <peripherals>
    <peripheral>
      <name>M06_ClockManager</name>
      <baseAddress>0x00000000</baseAddress>
      <registers>
        <register>
          <name>CLK_CTRL</name>
          <description>时钟控制：PLL 使能、时钟门控</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PLL_EN</name>
              <description>PLL 使能。1=使能，0=禁用</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>CLK_GATE_EN</name>
              <description>时钟门控使能。1=使能，0=禁用</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PLL_CFG</name>
          <description>PLL 配置：倍频系数、环路带宽</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00103D09</resetValue>
          <fields>
            <field>
              <name>DIV_RATIO</name>
              <description>PLL 倍频系数（15625 = 500MHz/32kHz）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>BW_CFG</name>
              <description>环路带宽配置</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CLK_STATUS</name>
          <description>时钟状态：PLL 锁定、时钟稳定</description>
          <addressOffset>0x08</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PLL_LOCK</name>
              <description>PLL 锁定状态。1=已锁定</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>CLK_STABLE</name>
              <description>时钟稳定指示。1=时钟输出稳定</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
