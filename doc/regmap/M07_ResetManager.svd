<?xml version="1.0" ?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Babel</vendor>
  <name>M07_ResetManager</name>
  <version>1.0</version>
  <description>M07_ResetManager Register Map</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <cpu>
    <name>CM0</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
  </cpu>
  <peripherals>
    <peripheral>
      <name>M07_ResetManager</name>
      <baseAddress>0x00000000</baseAddress>
      <registers>
        <register>
          <name>RST_CTRL</name>
          <description>复位控制：软件复位触发、复位范围、WDT 使能</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x0000000E</resetValue>
          <fields>
            <field>
              <name>SW_RST</name>
              <description>软件复位触发。写 1 触发复位，自动清零</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1s</access>
            </field>
            <field>
              <name>SCOPE</name>
              <description>复位范围。00=仅 sys，01=main+sys，11=全局</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>WDT_EN</name>
              <description>WDT 复位使能。1=使能，0=禁用</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>RST_STATUS</name>
          <description>复位状态：复位源标志、当前复位输出状态</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>POR_FLAG</name>
              <description>上次复位由 POR（上电复位）触发</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>WDT_FLAG</name>
              <description>上次复位由 WDT（看门狗）触发</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>SW_FLAG</name>
              <description>上次复位由软件触发</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RST_ACTIVE</name>
              <description>当前复位输出状态（任一复位源有效时为 1）</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>WDT_CFG</name>
          <description>看门狗配置：超时周期、喂狗、锁定</description>
          <addressOffset>0x08</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x0000FFFF</resetValue>
          <fields>
            <field>
              <name>WDT_PERIOD</name>
              <description>看门狗超时周期（CLK_AON 计数值）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>WDT_KICK</name>
              <description>喂狗操作。写 1 重置计数器，自动清零</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1s</access>
            </field>
            <field>
              <name>WDT_LOCK</name>
              <description>WDT_PERIOD 锁定。写 1 锁定，需 POR 解锁</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>18</bitOffset>
              <bitWidth>14</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
