<?xml version="1.0" ?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Babel</vendor>
  <name>M02_SRAM</name>
  <version>1.0</version>
  <description>M02_SRAM Register Map</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <cpu>
    <name>CM0</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
  </cpu>
  <peripherals>
    <peripheral>
      <name>M02_SRAM</name>
      <baseAddress>0x00000000</baseAddress>
      <registers>
        <register>
          <name>SRAM_CTRL</name>
          <description>控制寄存器：使能、ECC、Bank 模式</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000003</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>SRAM 使能。1=使能，0=禁用</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>ECC_EN</name>
              <description>ECC 使能。1=使能，0=禁用</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>BANK_MODE</name>
              <description>Bank 模式。00=独立，01=交织</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ECC_STATUS</name>
          <description>ECC 错误统计：SEC/DED 计数</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SEC_CNT</name>
              <description>单比特纠正累计计数</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>DED_CNT</name>
              <description>双比特检测累计计数</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>ro</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ECC_ADDR</name>
          <description>最近 ECC 错误地址</description>
          <addressOffset>0x08</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>ERR_ADDR</name>
              <description>最近 ECC 错误地址（19-bit 字地址）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>19</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>19</bitOffset>
              <bitWidth>13</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
