<?xml version="1.0" ?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Babel</vendor>
  <name>M01_DataflowController</name>
  <version>1.0</version>
  <description>M01_DataflowController Register Map</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <cpu>
    <name>CM0</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
  </cpu>
  <peripherals>
    <peripheral>
      <name>M01_DataflowController</name>
      <baseAddress>0x00000000</baseAddress>
      <registers>
        <register>
          <name>CTRL</name>
          <description>控制寄存器：全局使能、软复位、调度模式</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>GLOBAL_EN</name>
              <description>全局使能。1=使能，0=禁用</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>SOFT_RST</name>
              <description>软复位。写 1 触发内部复位，自清零</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>SCHED_MODE</name>
              <description>调度模式。00=顺序, 01=轮询, 10=优先级</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>状态寄存器：IDLE/BUSY、当前 TID、流水线阶段</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>IDLE</name>
              <description>空闲标志。1=模块空闲</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>BUSY</name>
              <description>忙标志。1=正在处理</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>CUR_TID</name>
              <description>当前线程 ID (0-1)</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>PIPE_STAGE</name>
              <description>当前流水线阶段 (0-F)</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>THREAD_CFG0</name>
          <description>线程 0 配置：精度、算子掩码</description>
          <addressOffset>0x08</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PRECISION</name>
              <description>精度选择。00=INT8, 01=FP16, 10=BF16</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>OP_MASK</name>
              <description>算子掩码。bit[n]=1 启用算子 n</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>THREAD_CFG1</name>
          <description>线程 1 配置：同上</description>
          <addressOffset>0x0C</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>PRECISION</name>
              <description>精度选择。00=INT8, 01=FP16, 10=BF16</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>OP_MASK</name>
              <description>算子掩码。bit[n]=1 启用算子 n</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>OP_QUEUE</name>
          <description>操作队列：基地址高 16 位、深度</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>QUEUE_BASE_HI</name>
              <description>队列基地址高 16 位</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>QUEUE_DEPTH</name>
              <description>队列深度（条目数）</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>rw</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PERF_CNT0</name>
          <description>线程 0 完成算子计数</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>COUNT</name>
              <description>线程 0 完成算子计数</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>ro</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PERF_CNT1</name>
          <description>线程 1 完成算子计数</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>COUNT</name>
              <description>线程 1 完成算子计数</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>ro</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PERF_UTIL</name>
          <description>流水线利用率（Q16 格式）</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>UTILIZATION</name>
              <description>流水线利用率（Q0.16 定点格式，0x10000=100%）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>ro</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQ_MASK</name>
          <description>中断使能掩码</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DONE_MASK</name>
              <description>完成中断使能。1=使能</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>ERROR_MASK</name>
              <description>错误中断使能。1=使能</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>QUEUE_FULL_MASK</name>
              <description>队列满中断使能。1=使能</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>3</bitOffset>
              <bitWidth>29</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>IRQ_STATUS</name>
          <description>中断状态，写 1 清零</description>
          <addressOffset>0x24</addressOffset>
          <size>32</size>
          <access>w1c</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>DONE_IRQ</name>
              <description>完成中断。写 1 清零</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1c</access>
            </field>
            <field>
              <name>ERROR_IRQ</name>
              <description>错误中断。写 1 清零</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1c</access>
            </field>
            <field>
              <name>QUEUE_FULL_IRQ</name>
              <description>队列满中断。写 1 清零</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1c</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>3</bitOffset>
              <bitWidth>29</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
