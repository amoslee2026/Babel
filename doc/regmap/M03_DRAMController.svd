<?xml version="1.0" ?>
<device xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.3" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Babel</vendor>
  <name>M03_DRAMController</name>
  <version>1.0</version>
  <description>M03_DRAMController Register Map</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <cpu>
    <name>CM0</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
  </cpu>
  <peripherals>
    <peripheral>
      <name>M03_DRAMController</name>
      <baseAddress>0x00000000</baseAddress>
      <registers>
        <register>
          <name>DRAM_CTRL</name>
          <description>控制寄存器：使能、自刷新、ECC</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x00000001</resetValue>
          <fields>
            <field>
              <name>EN</name>
              <description>控制器使能。1=使能，0=禁用</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>SELF_REFRESH</name>
              <description>自刷新模式。1=进入自刷新</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>ECC_EN</name>
              <description>ECC 使能。1=使能</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>ECC_IRQ_EN</name>
              <description>ECC 双比特错误中断使能</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>BURST_LEN</name>
              <description>突发长度配置（默认 BL8）</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留，必须写 0</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
              <access>-</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TIMING_CFG</name>
          <description>时序参数：tRCD、tCL、tRP、tRAS</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>rw</access>
          <resetValue>0x24121218</resetValue>
          <fields>
            <field>
              <name>tRCD</name>
              <description>行到列延迟（单位 CLK_SYS）</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>tCL</name>
              <description>CAS 延迟</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>tRP</name>
              <description>预充电时间</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>rw</access>
            </field>
            <field>
              <name>tRAS</name>
              <description>行激活时间</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>rw</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ECC_STATUS</name>
          <description>ECC 状态：SBE/DBE 标志、错误地址</description>
          <addressOffset>0x08</addressOffset>
          <size>32</size>
          <access>w1c</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SBE</name>
              <description>单比特错误标志。写 1 清零</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1c</access>
            </field>
            <field>
              <name>DBE</name>
              <description>双比特错误标志。写 1 清零</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>w1c</access>
            </field>
            <field>
              <name>RESERVED</name>
              <description>保留</description>
              <bitOffset>2</bitOffset>
              <bitWidth>14</bitWidth>
              <access>-</access>
            </field>
            <field>
              <name>ERR_ADDR</name>
              <description>最近错误地址高 16 位</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>ro</access>
            </field>
          </fields>
        </register>
        <register>
          <name>PERF_CNT</name>
          <description>性能计数器</description>
          <addressOffset>0x0C</addressOffset>
          <size>32</size>
          <access>ro</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>COUNT</name>
              <description>内存访问周期计数</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>ro</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
