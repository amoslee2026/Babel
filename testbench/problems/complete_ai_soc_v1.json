{
  "problem_id": "complete_ai_soc_v1",
  "version": "1.0.0",
  "difficulty": "Expert",
  "estimated_human_effort_hours": 400,
  "description": "设计一个完整的AI加速器SoC，包含16核NPU子系统、4核RISC-V控制子系统、NoC互联、分层缓存、DRAM控制器、PCIe接口，以及自定义NPU指令集。该设计覆盖IP设计、IP复用、SoC集成、指令集实现等完整芯片设计能力。",

  "input": {
    "design_idea": "设计一个面向边缘AI推理的完整SoC芯片。\n\n核心需求：\n1. **NPU子系统**：16个NPU核心，每个核心支持Transformer推理（Attention、MatMul、RMSNorm、RoPE），支持INT8/FP16混合精度，算力目标16 TOPS\n2. **CPU子系统**：4个RISC-V RV64GC核心，用于系统控制、任务调度、外设管理，支持Linux\n3. **IP复用**：复用开源DRAM控制器（支持DDR4/LPDDR4）、PCIe Gen3 x4控制器、JTAG调试接口\n4. **SoC集成**：2D Mesh NoC互联（4x4网格）、分层缓存（每NPU核心64KB L1、共享8MB L2）、多时钟域（NPU 1GHz、CPU 1.5GHz、NoC 800MHz）、完整CDC处理\n5. **指令集实现**：自定义NPU ISA（32条指令），包含矩阵运算、向量运算、数据搬运、同步原语，提供ISA解码器和合规测试套件\n6. **外设接口**：DDR4控制器（32-bit, 2400MT/s）、PCIe Gen3 x4、JTAG、UART、SPI、GPIO\n7. **电源管理**：DVFS（4个电压域）、时钟门控、电源门控（NPU核心可独立关断）\n8. **安全启动**：Secure Boot ROM、密钥管理、固件签名验证\n\n工艺约束：ASAP7 7nm PDK，目标频率1GHz（NPU）/1.5GHz（CPU），面积≤50mm²，功耗≤15W",

    "constraints": {
      "technology": "asap7",
      "process_node": "7nm",
      "clock_frequencies": {
        "npu_core_mhz": 1000,
        "cpu_core_mhz": 1500,
        "noc_mhz": 800,
        "dram_mhz": 1200,
        "pcie_mhz": 250
      },
      "area_budget_mm2": 50,
      "power_budget_w": 15,
      "voltage_domains": ["VDD_NPU", "VDD_CPU", "VDD_NOC", "VDD_IO"],
      "clock_domains": ["clk_npu", "clk_cpu", "clk_noc", "clk_dram", "clk_pcie", "clk_jtag"],
      "performance_targets": {
        "npu_tops": 16,
        "cpu_dhrystone_dmips": 8000,
        "memory_bandwidth_gbs": 20,
        "pcie_bandwidth_gbs": 4
      }
    },

    "quality_gates": {
      "arch_stage": {
        "schema_validation": "MAS schema必须通过验证",
        "module_count": "25-35个模块",
        "clock_domains": "至少6个时钟域",
        "interface_coverage": "所有外部接口（DDR/PCIe/JTAG）必须有明确定义"
      },
      "rtl_stage": {
        "lint_clean": "Verilator lint零警告",
        "cdc_clean": "所有CDC路径必须有同步器",
        "code_coverage": "行覆盖率100%，分支覆盖率100%",
        "functional_coverage": "功能覆盖率100%（包括NPU指令集、CPU指令集、NoC路由、CDC路径）"
      },
      "verification_stage": {
        "test_pass_rate": "100%测试通过",
        "isa_compliance": "NPU ISA合规测试100%通过",
        "riscv_compliance": "RISC-V RV64GC合规测试100%通过",
        "noc_deadlock_free": "NoC无死锁验证通过",
        "cdc_verification": "所有CDC路径时序验证通过"
      },
      "synthesis_stage": {
        "timing_closure": "WNS≥0，所有时钟域满足时序",
        "area_utilization": "面积≤50mm²",
        "power_estimation": "功耗≤15W",
        "drc_clean": "Yosys综合零DRC错误"
      },
      "pd_stage": {
        "drc_clean": "Magic DRC零违规",
        "lvs_clean": "Netgen LVS匹配",
        "routing_completion": "100%布线完成",
        "timing_signoff": "OpenSTA signoff WNS≥0"
      }
    }
  },

