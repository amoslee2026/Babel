  "scoring": {
    "dimensions": {
      "correctness": {
        "weight": 0.25,
        "sub_metrics": [
          {
            "name": "arch_stage_pass_rate",
            "weight": 0.2,
            "formula": "MAS schema验证通过 ? 1.0 : 0.0"
          },
          {
            "name": "rtl_stage_pass_rate",
            "weight": 0.2,
            "formula": "(lint_clean + cdc_clean + coverage_100) / 3"
          },
          {
            "name": "verification_stage_pass_rate",
            "weight": 0.25,
            "formula": "test_pass_rate * isa_compliance * riscv_compliance * noc_deadlock_free * cdc_verified"
          },
          {
            "name": "synthesis_stage_pass_rate",
            "weight": 0.2,
            "formula": "(WNS>=0) ? 1.0 : 0.0"
          },
          {
            "name": "pd_stage_pass_rate",
            "weight": 0.15,
            "formula": "(DRC_clean + LVS_clean + routing_complete) / 3"
          }
        ]
      },
      "completeness": {
        "weight": 0.20,
        "sub_metrics": [
          {
            "name": "module_coverage",
            "weight": 0.3,
            "formula": "实际模块数 / 预期模块数（25-35）"
          },
          {
            "name": "interface_coverage",
            "weight": 0.25,
            "formula": "实际接口数 / 预期接口数（6外部+45内部）"
          },
          {
            "name": "clock_domain_coverage",
            "weight": 0.2,
            "formula": "实际时钟域数 / 预期时钟域数（6）"
          },
          {
            "name": "test_scenario_coverage",
            "weight": 0.25,
            "formula": "实际测试场景数 / 预期测试场景数（30+）"
          }
        ]
      },
      "quality": {
        "weight": 0.20,
        "sub_metrics": [
          {
            "name": "timing_margin",
            "weight": 0.3,
            "formula": "min(1.0, max(0, WNS / clock_period))"
          },
          {
            "name": "area_efficiency",
            "weight": 0.25,
            "formula": "max(0, 1.0 - (实际面积 - 预算面积) / 预算面积)"
          },
          {
            "name": "power_efficiency",
            "weight": 0.25,
            "formula": "max(0, 1.0 - (实际功耗 - 预算功耗) / 预算功耗)"
          },
          {
            "name": "performance_achievement",
            "weight": 0.2,
            "formula": "(npu_tops_achieved / 16) * (cpu_dmips_achieved / 8000)"
          }
        ]
      },
      "efficiency": {
        "weight": 0.15,
        "sub_metrics": [
          {
            "name": "token_efficiency",
            "weight": 0.4,
            "formula": "参考token数 / 实际token数（上限1.0）"
          },
          {
            "name": "tool_call_efficiency",
            "weight": 0.3,
            "formula": "参考tool call数 / 实际tool call数（上限1.0）"
          },
          {
            "name": "stage_transition_efficiency",
            "weight": 0.3,
            "formula": "成功阶段转换数 / 总阶段转换数（4次转换）"
          }
        ]
      },
      "robustness": {
        "weight": 0.10,
        "sub_metrics": [
          {
            "name": "error_recovery_rate",
            "weight": 0.5,
            "formula": "自动修复成功次数 / 总错误次数"
          },
          {
            "name": "cdc_handling_quality",
            "weight": 0.3,
            "formula": "正确处理CDC路径数 / 总CDC路径数"
          },
          {
            "name": "timing_closure_iterations",
            "weight": 0.2,
            "formula": "max(0, 1.0 - (迭代次数 - 1) / 5)"
          }
        ]
      },
      "cost_effectiveness": {
        "weight": 0.10,
        "sub_metrics": [
          {
            "name": "usd_per_pipeline",
            "weight": 0.5,
            "formula": "参考成本 / 实际成本（上限1.0）"
          },
          {
            "name": "token_per_stage",
            "weight": 0.3,
            "formula": "参考token/stage / 实际token/stage（上限1.0）"
          },
          {
            "name": "time_to_completion",
            "weight": 0.2,
            "formula": "参考时间 / 实际时间（上限1.0）"
          }
        ]
      }
    },
    "final_score_formula": "Σ(dimension_score * dimension_weight)",
    "passing_threshold": 0.70
  },

