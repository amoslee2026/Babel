//-----------------------------------------------------------------------------
// Module: NPU_top
// Type:   Top-Level Integration Module
// Version: v1.1 - Simplified Integration for Synthesis
//-----------------------------------------------------------------------------
// Description:
//   Simplified top-level integration with minimal port connections for synthesis.
//   All sub-modules instantiated with essential connections only.
//-----------------------------------------------------------------------------

module NPU_top (
    //=========================================================================
    // Primary IO
    //=========================================================================
    input  logic        ext_clk_50MHz,
    input  logic        ext_rst_por_n,
    input  logic        pll_lock_ext,
    output logic        pll_pwr_en,
    output logic        irq_compute_done,
    output logic        status_sec_boot_done
);

//=========================================================================
// Internal Signals
//=========================================================================

logic        clk_sys;
logic        clk_aon;
logic        clk_io;
logic        rst_sys_n;
logic        pg_main_en;
logic        sec_boot_done;
logic        sec_boot_fail;
logic        sec_lockdown;

//=========================================================================
// M06: Clock Manager
//=========================================================================

M06_ClockManager u_M06_ClockManager (
    .ext_clk_i       (ext_clk_50MHz),
    .pll_lock_i      (pll_lock_ext),
    .dvfs_op_i       (2'b0),
    .dvfs_req_i      (1'b0),
    .clk_gating_en_i (14'h3FFF),
    .pd_aon_vdd_i    (1'b1),
    .clk_sys_o       (clk_sys),
    .clk_aon_o       (clk_aon),
    .clk_io_o        (clk_io),
    .clk_gating_o    (),
    .dvfs_ack_o      (),
    .clk_status_o    (),
    .pll_pwr_en_o    (pll_pwr_en)
);

//=========================================================================
// Reset Distribution
//=========================================================================

always_ff @(posedge clk_aon or negedge ext_rst_por_n) begin
    if (!ext_rst_por_n) begin
        rst_sys_n <= 1'b0;
    end else begin
        if (pll_lock_ext && pll_pwr_en) begin
            rst_sys_n <= 1'b1;
        end
    end
end

//=========================================================================
// M05: Power Manager
//=========================================================================

M05_PowerManager u_M05_PowerManager (
    .clk_aon         (clk_aon),
    .rst_aon_n       (ext_rst_por_n),
    .rst_por_n       (ext_rst_por_n),
    .bus_cmd_valid   (1'b0),
    .bus_cmd_ready   (),
    .bus_cmd_addr    (16'b0),
    .bus_cmd_rw      (1'b0),
    .bus_cmd_data    (32'b0),
    .bus_rsp_valid   (),
    .bus_rsp_data    (),
    .bus_rsp_error   (),
    .dvfs_op_req     (),
    .dvfs_op_ack     (1'b0),
    .dvfs_vdd_req    (),
    .dvfs_freq_req   (),
    .pg_main_en_o    (pg_main_en),
    .pg_aon_en_o     (),
    .pg_io_en_o      (),
    .pg_dram_en_o    (),
    .pg_status_o     (),
    .sec_boot_en_i   (sec_boot_done),
    .sec_lockdown_i  (sec_lockdown),
    .dvfs_busy_o     ()
);

