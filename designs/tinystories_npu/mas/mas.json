{
  "design_name": "tinystories_npu",
  "top_module": "NPU_top",
  "target_freq_mhz": 500,
  "target_pdk": "asap7",
  "area_budget_um2": 90000000,
  "power_budget_mw": 1800,
  "clock_domains": [
    {"name": "clk_sys", "freq_mhz": 500, "source": "PLL (M06), VCO/2"},
    {"name": "clk_io", "freq_mhz": 50, "source": "PLL (M06), VCO/20"},
    {"name": "clk_aon", "freq_mhz": 0.032, "source": "Internal RC oscillator (M06)"},
    {"name": "clk_d2d", "freq_mhz": 625, "source": "PLL (M06), DDR"}
  ],
  "io_timing": {
    "inputs": [
      {"name": "ext_clk_50MHz", "width": 1, "delay_ns": 0.5, "description": "External 50 MHz oscillator input; note: ARCH says 25 MHz but existing netlist uses 50 MHz"},
      {"name": "ext_rst_por_n", "width": 1, "delay_ns": 0.5, "description": "External power-on reset, active low"},
      {"name": "pll_lock_ext", "width": 1, "delay_ns": 0.5, "description": "PLL lock indicator from external analog PLL"},
      {"name": "TCK", "width": 1, "delay_ns": 1.0, "description": "JTAG test clock"},
      {"name": "TMS", "width": 1, "delay_ns": 1.0, "description": "JTAG test mode select"},
      {"name": "TDI", "width": 1, "delay_ns": 1.0, "description": "JTAG test data in"},
      {"name": "TRST_n", "width": 1, "delay_ns": 1.0, "description": "JTAG test reset"},
      {"name": "isa_cmd_i", "width": 32, "delay_ns": 1.0, "description": "ISA command input bus"},
      {"name": "isa_cmd_valid_i", "width": 1, "delay_ns": 1.0, "description": "ISA command valid"},
      {"name": "isa_rsp_ready_i", "width": 1, "delay_ns": 1.0, "description": "ISA response ready from host"}
    ],
    "outputs": [
      {"name": "pll_pwr_en", "width": 1, "delay_ns": 0.5, "description": "PLL power enable to external analog PLL"},
      {"name": "irq_compute_done", "width": 1, "delay_ns": 0.5, "description": "Compute done interrupt to host"},
      {"name": "status_sec_boot_done", "width": 1, "delay_ns": 0.5, "description": "Secure boot status indicator"},
      {"name": "TDO", "width": 1, "delay_ns": 1.0, "description": "JTAG test data out"},
      {"name": "isa_cmd_ready_o", "width": 1, "delay_ns": 1.0, "description": "ISA command ready to host"},
      {"name": "isa_rsp_o", "width": 32, "delay_ns": 1.0, "description": "ISA response output bus"},
      {"name": "isa_rsp_valid_o", "width": 1, "delay_ns": 1.0, "description": "ISA response valid to host"}
    ]
  },
  "io_ring": [
    {"side": "N", "pads": ["ext_clk_50MHz", "ext_rst_por_n", "pll_lock_ext", "pll_pwr_en"]},
    {"side": "S", "pads": ["irq_compute_done", "status_sec_boot_done"]},
    {"side": "E", "pads": ["TCK", "TMS", "TDI", "TDO", "TRST_n"]},
    {"side": "W", "pads": ["isa_cmd_i", "isa_cmd_valid_i", "isa_cmd_ready_o", "isa_rsp_o", "isa_rsp_valid_o", "isa_rsp_ready_i"]}
  ],
  "cdc_waivers": [
    {"from_clk": "clk_sys", "to_clk": "clk_io", "signal": "M04_bus_to_M15_M16", "justification": "2-stage synchronizer (single-bit) / Async FIFO (bus data); standard async domain crossing"},
    {"from_clk": "clk_io", "to_clk": "clk_sys", "signal": "M15_M16_bus_to_M04", "justification": "2-stage synchronizer / Async FIFO"},
    {"from_clk": "clk_sys", "to_clk": "clk_aon", "signal": "dvfs_req_from_M05", "justification": "Handshake protocol (req/ack); low rate <1kHz, no timing requirement"},
    {"from_clk": "clk_aon", "to_clk": "clk_sys", "signal": "status_from_M05_M06_M07", "justification": "2-stage synchronizer; status signals stable for many cycles"},
    {"from_clk": "clk_sys", "to_clk": "clk_d2d", "signal": "M03_dma_to_d2d", "justification": "Async FIFO internal to M03; dedicated D2D data path"}
  ],
  "path_exceptions": [
    {"type": "false_path", "from": "clk_sys", "to": "clk_aon", "cycles": null},
    {"type": "false_path", "from": "clk_aon", "to": "clk_sys", "cycles": null},
    {"type": "false_path", "from": "clk_sys", "to": "clk_io", "cycles": null},
    {"type": "multicycle", "from": "M00_weight_buf", "to": "M00_PE_reg", "cycles": 2},
    {"type": "multicycle", "from": "M03_dma_req", "to": "M03_d2d_cmd", "cycles": 3}
  ],
