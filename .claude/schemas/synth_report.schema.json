{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://babel.local/schemas/synth_report.schema.json",
  "title": "SynthReport",
  "type": "object",
  "additionalProperties": true,
  "required": ["design_name", "top_module", "wns_ns", "tns_ns", "area_um2", "cell_count", "corners", "outputs", "inputs", "iteration_count"],
  "properties": {
    "design_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$"
    },
    "top_module":  {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,63}$"
    },
    "netlist":     {
      "type": "string",
      "pattern": "^[A-Za-z0-9_/.,+-]+$",
      "description": "path to synth/netlist.v; restricted charset"
    },
    "wns_ns":      {"type": "number", "description": "worst-corner WNS"},
    "tns_ns":      {"type": "number"},
    "timing_met":  {"type": "boolean"},
    "area_um2":    {"type": "number", "exclusiveMinimum": 0},
    "cell_count":  {"type": "integer", "minimum": 0},
    "util":        {"type": "number"},
    "corners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["corner", "wns_ns", "timing_met"],
        "properties": {
          "corner":     {"type": "string"},
          "wns_ns":     {"type": "number"},
          "tns_ns":     {"type": "number"},
          "timing_met": {"type": "boolean"}
        }
      }
    },
    "cdc_clean":   {"type": "boolean"},
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "description": "Files this stage produced (netlist + qor). Downstream PD recomputes sha256 and compares for freshness.",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "iteration_count": {"type": "integer", "minimum": 0, "maximum": 8}
  }
}
