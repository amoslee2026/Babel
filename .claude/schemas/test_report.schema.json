{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://babel.local/schemas/test_report.schema.json",
  "title": "TestReport",
  "description": "Canonical verification handoff. Coverage uses NESTED layout (fix C-01).",
  "type": "object",
  "additionalProperties": true,
  "required": ["design_name", "functional_coverage", "code_coverage", "tests", "inputs", "iteration_count"],
  "properties": {
    "design_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$"
    },
    "functional_coverage": {"type": "number", "minimum": 0, "maximum": 100},
    "code_coverage": {
      "type": "object",
      "required": ["line", "branch", "toggle"],
      "properties": {
        "line":   {"type": "number", "minimum": 0, "maximum": 100},
        "branch": {"type": "number", "minimum": 0, "maximum": 100},
        "toggle": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name":   {"type": "string"},
          "status": {"enum": ["pass", "fail", "skip"]},
          "log":    {"type": "string"}
        }
      }
    },
    "uncovered_bins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "group": {"type": "string"},
          "bin":   {"type": "string"},
          "hits":  {"type": "integer"}
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "iteration_count": {"type": "integer", "minimum": 0, "maximum": 8}
  }
}
