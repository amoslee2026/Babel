{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://babel.local/schemas/rtl_artifact.schema.json",
  "title": "RTLArtifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["design_name", "top_module", "modules", "file_list", "outputs", "inputs", "lint_clean"],
  "properties": {
    "design_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$",
      "description": "Directory slug under designs/; lowercase alphanumeric + _ -"
    },
    "top_module":  {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,63}$",
      "description": "SystemVerilog top-level module name; shell/TCL-safe identifier"
    },
    "modules": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "file"], "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,63}$",
          "description": "SystemVerilog module name"
        },
        "file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_/.,+-]+$",
          "description": "Relative path; restricted charset to prevent path traversal + shell escape"
        }
      }}
    },
    "file_list":   {
      "type": "string",
      "pattern": "^[A-Za-z0-9_/.,+-]+$",
      "description": "path to file_list.f; restricted charset"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "lint_clean": {"type": "boolean"},
    "iteration_count": {"type": "integer", "minimum": 0, "maximum": 8}
  }
}
