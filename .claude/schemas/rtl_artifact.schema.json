{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://babel.local/schemas/rtl_artifact.schema.json",
  "title": "RTLArtifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["design_name", "top_module", "modules", "file_list", "outputs", "inputs", "lint_clean"],
  "properties": {
    "design_name": {"type": "string"},
    "top_module":  {"type": "string"},
    "modules": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "file"], "properties": {
        "name": {"type": "string"},
        "file": {"type": "string"}
      }}
    },
    "file_list":   {"type": "string", "description": "path to file_list.f"},
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "lint_clean": {"type": "boolean"},
    "iteration_count": {"type": "integer", "minimum": 0, "maximum": 8}
  }
}
