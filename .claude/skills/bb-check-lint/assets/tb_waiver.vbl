// Verilator waiver file for testbench patterns
// Apply to *_tb.sv and *_tb.v files
lint_off -rule INITIAL_BLOCK -file "*_tb.sv"  // Allow initial blocks
lint_off -rule INITIAL_BLOCK -file "*_tb.v"
lint_off -rule SYSTEM_TASK   -file "*_tb.sv"  // Allow $display, $monitor, $finish
lint_off -rule SYSTEM_TASK   -file "*_tb.v"
lint_off -rule DELAY         -file "*_tb.sv"  // Allow delays (#)
lint_off -rule DELAY         -file "*_tb.v"
lint_off -rule UNUSEDSIGNAL  -file "*_tb.sv"  // Allow unused stimulus signals
lint_off -rule UNUSEDSIGNAL  -file "*_tb.v"
lint_off -rule WIDTH         -file "*_tb.sv"  // Allow wide concatenations
lint_off -rule WIDTH         -file "*_tb.v"
