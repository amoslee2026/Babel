// Verilator Lint Waiver File
// Babel Project - ASAP7 Design Flow
//
// Usage: verilator --lint-only -Wno-fatal -f this_file.vbl
//
// Waiver syntax:
//   lint_off -msg <MSG_ID> [-file <glob>] [-match <pattern>]

// Testbench-only waivers (do not apply to RTL)
lint_off -msg UNUSED         -file "*_tb.sv"
lint_off -msg PINCONNECTEMPTY -file "*_tb.sv"
lint_off -msg BLKSEQ         -file "*_tb.sv"

// Generated code waivers
lint_off -msg DECLFILENAME   -file "*_generated*"
lint_off -msg VARHIDDEN      -file "*_generated*"

// Known false positives from parameterized modules
lint_off -msg WIDTH          -file "*/cbb/*"  -match "*param*"
lint_off -msg UNOPTFLAT      -file "*/fifo_*"
